{{#if placemark}}
  <div id="placemark-map" style="height: 400px;"></div>
{{/if}}

<script>

  console.log("DEBUG - Color is:", "{{placemark.design.color}}");
  console.log("DEBUG - Icon is:", "{{placemark.design.icon}}");
  const map = L.map('placemark-map').setView([{{placemark.lat}}, {{placemark.lng}}], 13);

  const popupHtml = `
    <div class="is-flex is-align-items-center">
      <span class="icon has-text-{{placemark.design.colour}} is-medium mr-2">
        <i class="{{placemark.design.icon}} fa-lg"></i>
      </span>
      <div>
        <p class="has-text-weight-bold">{{placemark.name}} </p>
        <p class="is-size-6"> {{placemark.category}}</p>
      </div>
    </div>
  `;
  
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 14,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
    }).addTo(map);

    L.marker([{{placemark.lat}}, {{placemark.lng}}])
      .addTo(map)
      .bindPopup(popupHtml )
      .openPopup();
</script>

