<div class="box">
  <form action="/dashboard/addplacemark" method="POST">
    
    <div class="field is-horizontal">
      <div class="field-body">
        <div class="field">
          <label class="label">Adventure Name</label>
          <div class="control">
            <input class="input" type="text" placeholder="e.g. The Forty Foot" name="name">
          </div>
        </div>
        <div class="field">
          <label class="label">Category</label>
          <div class="control">
            <div class="select is-fullwidth">
              <select name="category">
                <option value="" disabled selected>Select activity type...</option>
                {{#each categories}}
                  <option value="{{this}}">{{this}}</option>
                {{/each}}
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="field">
      <label class="label">Description (Max 200 chars)</label>
      <div class="control">
        <textarea class="textarea" placeholder="Describe the spot" name="description" maxlength="200"></textarea>
      </div>
    </div>

    <div class="field is-horizontal">
      <div class="field-body">
        <div class="field">
          <label class="label">Time Required</label>
          <div class="control">
            <div class="select is-fullwidth">
              <select name="timeRequired">
                <option value="" disabled selected>Select duration...</option>
                <option value="1 hour">1 hour</option>
                <option value="2 hours">2 hours</option>
                <option value="Half day">Half day</option>
                <option value="Full day">Full day</option>
                <option value="Overnight">Overnight</option>
              </select>
            </div>
          </div>
        </div>
        <div class="field">
          <label class="label">Amenities (Comma separated)</label>
          <div class="control">
            <input class="input" type="text" placeholder="e.g. Parking, Toilets, Cafe" name="amenities">
          </div>
        </div>
      </div>
    </div>

    <div class="field is-horizontal">
      <div class="field-body">
        <div class="field">
          <label class="label">Latitude</label>
          <div class="control">
            <input class="input" type="number" step="any" placeholder="53.289" name="lat">
          </div>
        </div>
        <div class="field">
          <label class="label">Longitude</label>
          <div class="control">
            <input class="input" type="number" step="any" placeholder="-6.115" name="lng">
          </div>
        </div>
        <div class="field">
          <label class="label">Image URL</label>
          <div class="control">
            <input class="input" type="text" placeholder="https://..." name="image">
          </div>
        </div>
      </div>
    </div>

    <button class="button is-primary is-fullwidth mt-4">Add Adventure Spot</button>
  </form>
</div>