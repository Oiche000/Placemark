{{#if errors}}
  <div class="box content">
    <p> There was a problem... </p>
    <ul>
      {{#each errors}}
        <li>{{message}}</li>
      {{/each}}
    </ul>
  </div>
{{/if}}

{{#if errors}}
  <div class="box content notification is-danger is-light">
    <button class="delete"></button>
    <p class="has-text-weight-bold">There was a problem with your entry</p>
    <ul>
      {{#each errors}}
        <li> {{message}}</li>
      {{/each}}
    </ul>
  </div>
{{/if}}